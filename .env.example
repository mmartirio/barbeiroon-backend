# Backend Server
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha
DB_NAME=meu_barbeiro
DB_DIALECT=mysql

# JWT Secret
JWT_SECRET=sua_chave_secreta_super_segura_aqui_12345

# Frontend URL (usado para gerar links nos e-mails)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail)
# Para usar Gmail, você precisa:
# 1. Ativar autenticação de 2 fatores na sua conta Google
# 2. Gerar uma senha de app em https://myaccount.google.com/apppasswords
# 3. Usar a senha de app no campo EMAIL_PASS
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app-do-gmail
EMAIL_FROM="Meu Barbeiro <noreply@meubarbeiro.com>"

# Outros provedores de e-mail:
# 
# SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=sua-api-key-do-sendgrid
#
# Amazon SES:
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USER=seu-smtp-username
# EMAIL_PASS=seu-smtp-password
#
# Mailgun:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USER=seu-usuario-mailgun
# EMAIL_PASS=sua-senha-mailgun

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# CORS
CORS_ORIGIN=http://localhost:3000

# WhatsApp Notifications (conclusao de agendamento)
# Provedor suportado: callmebot (padrao) ou meta
WHATSAPP_PROVIDER=callmebot

# O destino do WhatsApp vem do campo Telefone da Conta (tenant.phone).
# Mantido aqui apenas para compatibilidade futura, atualmente nao e utilizado.
WHATSAPP_BARBER_PHONE=

# CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
WHATSAPP_CALLMEBOT_API_KEY=

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── PIX (cobranças via Pix Copia e Cola) ───────────────────────────────────
# Configurado pelo painel gestor em Cobranças → Chave PIX
# Não requer variáveis de ambiente — dados salvos no banco de dados
